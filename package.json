{
  "name": "era-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "$npm_execpath run build:articles && $npm_execpath run build:events && $npm_execpath --hot src/index.ts",
    "start": "NODE_ENV=production $npm_execpath src/index.ts",
    "build:articles": "$npm_execpath run scripts/process-articles.ts",
    "build:events": "$npm_execpath run scripts/process-events.ts",
    "build:site": "$npm_execpath run build.ts",
    "build": "$npm_execpath run build:articles && $npm_execpath run build:events && $npm_execpath run build:site",
    "content": "$npm_execpath run build:articles && $npm_execpath run build:events",
    "postinstall": "$npm_execpath run content"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-router": "^1.139.3",
    "@touch4it/ical-timezones": "^1.9.0",
    "bun-plugin-tailwind": "^0.1.2",
    "clsx": "^2.1.1",
    "daisyui": "5",
    "framer-motion": "^12.23.24",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "ical-generator": "^11.0.0",
    "isomorphic-dompurify": "^2.34.0",
    "luxon": "^3.7.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype": "^13.0.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-prism-plus": "^2.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "rrule": "^2.8.1",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.11",
    "twgl.js": "^7.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/hast": "^3.0.4",
    "@types/katex": "^0.16.7",
    "@types/luxon": "^3.7.1",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3"
  }
}
